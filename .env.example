# ========== Server ==========
PORT=3000
HOST=0.0.0.0

# ========== Admin Reset ==========
# Password for resetting the game (POST /api/reset)
# If not set or empty, all reset requests will be rejected with "password error"
RESET_PASSWORD=

# ========== NES ROM ==========
ROM_PATH=./roms/game.nes

# ========== Game Session ==========
# Maximum play time per player (seconds)
MAX_PLAY_TIME_SECONDS=300
# Countdown warning before turn ends (seconds)
COUNTDOWN_SECONDS=10
# Maximum queue size
MAX_QUEUE_SIZE=50

# ========== Audio ==========
AUDIO_SAMPLE_RATE=44100

# ========== Snapshot ==========
# Snapshot interval in seconds (default 1)
SNAPSHOT_INTERVAL_SECONDS=1
# Archive every N snapshots (default 3600, i.e. ~1 hour at 1s interval)
SNAPSHOT_ARCHIVE_EVERY_N=3600
# Maximum number of archive snapshots to keep
SNAPSHOT_MAX_ARCHIVES=72
# Snapshot storage directory (can be absolute or relative)
SNAPSHOT_DIR=./snapshots

# ========== Frame Encoding ==========
# Send full keyframe every N frames (for new viewers / recovery)
KEYFRAME_INTERVAL=300
