# ========== Server ==========
PORT=3000
HOST=0.0.0.0

# ========== NES ROM ==========
ROM_PATH=./roms/game.nes

# ========== Game Session ==========
# Maximum play time per player (seconds)
MAX_PLAY_TIME_SECONDS=300
# Countdown warning before turn ends (seconds)
COUNTDOWN_SECONDS=10
# Maximum queue size
MAX_QUEUE_SIZE=50

# ========== Audio ==========
AUDIO_SAMPLE_RATE=44100

# ========== Frame Encoding ==========
# Send full keyframe every N frames (for new viewers / recovery)
KEYFRAME_INTERVAL=300
